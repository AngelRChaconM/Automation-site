{
  "name": "automation-site",
  "version": "1.0.0",
  "description": "Practice site for test automation (Playwright, Cypress, WebdriverIO, Selenium, ...). Vite + React + TS.",
  "type": "module",
  "scripts": {
    "start": "vite --port 3000 --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3000 --host",
    "test:pw": "playwright test",
    "test:pw:ui": "playwright test --ui"
  },
  "keywords": [
    "automation",
    "testing",
    "playwright",
    "cypress"
  ],
  "author": "",
